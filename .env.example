# Copy to .env and adjust. All values optional except where noted.

# Host/port for the web dashboard
BIDBUD_HOST=0.0.0.0
BIDBUD_PORT=8000

# Secret used to encrypt your stored TradeMe password (Fernet key).
# If unset, a key is generated and stored in data/secret.key on first run.
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BIDBUD_SECRET_KEY=

# Optional HTTP basic-auth to protect the dashboard (recommended if exposed).
# Leave blank to disable.
BIDBUD_UI_USER=
BIDBUD_UI_PASS=

# Run the browser headless (1) or headed (0). On a server keep this 1.
BIDBUD_HEADLESS=1

# How many seconds before an auction closes the bidding engine "wakes up"
# and starts fine-grained monitoring. The strategies themselves all act
# within the final 2 minutes; this just gives the engine a head start.
BIDBUD_ENGINE_LEAD_SECONDS=180
